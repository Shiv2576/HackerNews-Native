{
  "expo": {
    "name": "Hacker News",
    "slug": "hnnews",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/HackerNews.png",
    "scheme": "hnnews",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/HackerNews.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anng2576.hnnews"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "anng2576",
    "extra": {
      "eas": {
        "projectId": "b4f46087-c273-4657-af8a-1557c7e6f891"
      }
    }
  }
}
